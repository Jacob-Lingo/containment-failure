# Place this file at the ROOT of your Unity project (next to Assets/, Packages/, ProjectSettings/).
# Based on the official GitHub Unity.gitignore template.

# ---- Unity-generated folders (regenerable, never commit) ----
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta files should NOT be ignored even if the folder pattern would catch them
!/[Aa]ssets/**/*.meta

# Autogenerated Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# IDE / editor caches
.vs/
.gradle/
.consulo/
.idea/

# Autogenerated solution/project files (regenerated by Unity per machine)
ExportedObj/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
*.slnx

# Unity generated meta for the above
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash report
sysinfo.txt

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
